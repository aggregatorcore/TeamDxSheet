# Copy to .env and fill with your Supabase project values (same as webapp .env.local)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web app base URL for admin actions (move to exhaust/review). Required for Invalid Number, Not Interested, WhatsApp Not Available.
EXPO_PUBLIC_API_URL=https://your-app.onrender.com
